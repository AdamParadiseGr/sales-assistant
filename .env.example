# Primary Groq API key (used as fallback if numbered keys are not set)
GROQ_API_KEY=gsk_...

# Multiple Groq API keys for automatic rotation on rate-limit (HTTP 429).
# Add as many as you have. Keys are tried in order: _1 → _2 → _3 → ...
# If all keys are exhausted, the user sees a "try again later" message.
GROQ_API_KEY_1=your_key_here
GROQ_API_KEY_2=your_key_here
GROQ_API_KEY_3=your_key_here

GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

TELEGRAM_BOT_TOKEN=...
CHROMA_PERSIST_DIR=./chroma_db
LEADS_DB_PATH=./leads.db
LOG_LEVEL=INFO
